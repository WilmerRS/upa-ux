{
  "short_name": "UPA-UX",
  "name": "UPA UX",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "app/background.js"
  },
  "browser_action": {},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["/css/root.css"],
      "js": ["/static/js/content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["/static/css/content.css", "/static/media/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
